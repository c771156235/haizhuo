/**
 * 宸ュ崟璇︽儏椤甸潰
 */
import { useState } from 'react'
import { useParams, useNavigate, useLocation } from 'react-router-dom'
import { useQuery, useMutation, useQueryClient } from 'react-query'
import { Card, Descriptions, Tag, Button, Result, Space, Modal, Form, message, Input } from 'antd'
import { workOrderService } from '../services/workOrder'
import { useAuth } from '../contexts/AuthContext'
import { UserRole } from '../types/user'
import UserSelector from '../components/UserSelector'
import Loading from '../components/Loading'
import ErrorBoundary from '../components/ErrorBoundary'
import { PageBreadcrumb } from '../components/PageBreadcrumb'
import dayjs from 'dayjs'
import { extractErrorMessage } from '../utils/errorHandler'

const WorkOrderStatusLabels: Record<string, string> = {
  pending_assign: '待转派',
  pending_accept: '待接单',
  accepted: '已接单',
  in_progress: '进行中',
  completed: '已拜访',
  cancelled: '已取消',
  // 兼容旧数据
  pending: '待接单',
}

const WorkOrderStatusColors: Record<string, string> = {
  pending_assign: 'orange',
  pending_accept: 'orange',
  accepted: 'blue',
  in_progress: 'processing',
  completed: 'success',
  cancelled: 'default',
  // 兼容旧数据
  pending: 'orange',
}

const WorkOrderDetail = () => {
  const { id } = useParams<{ id: string }>()
  const navigate = useNavigate()
  const location = useLocation()
  const { user, getCurrentRole } = useAuth()
  const currentRole = getCurrentRole()
  const queryClient = useQueryClient()
  
  // 从 location 获取来源页面的查询参数（分页信息）
  const getReturnUrl = () => {
    const searchParams = new URLSearchParams(location.search)
    // 如果有查询参数，返回时带上这些参数
    if (searchParams.toString()) {
      return `/work-orders?${searchParams.toString()}`
    }
    return '/work-orders'
  }
  const [assignModalVisible, setAssignModalVisible] = useState(false)
  const [assignForm] = Form.useForm()
  const [updateTeamLeaderModalVisible, setUpdateTeamLeaderModalVisible] = useState(false)
  const [updateTeamLeaderForm] = Form.useForm()
  const [cancelModalVisible, setCancelModalVisible] = useState(false)
  const [cancelForm] = Form.useForm()

  const { data: workOrder, isLoading, error, refetch } = useQuery(
    ['workOrder', id],
    () => workOrderService.getWorkOrder(Number(id!)),
    { enabled: !!id }
  )

  // 鎺ュ崟 mutation
  const acceptMutation = useMutation(
    (id: number) => workOrderService.acceptWorkOrder(id),
    {
      onSuccess: () => {
        message.success('鎺ュ崟鎴愬姛')
        queryClient.invalidateQueries(['workOrder', id])
        queryClient.invalidateQueries('workOrders')
        queryClient.invalidateQueries('notificationUnreadCount')
        queryClient.invalidateQueries('notificationsRecent')
      },
      onError: (error: any) => {
        message.error(extractErrorMessage(error, '鎺ュ崟澶辫触'))
      },
    }
  )

  // 杞淳 mutation
  const assignMutation = useMutation(
    ({ id, member_id }: { id: number; member_id: number }) =>
      workOrderService.assignWorkOrder(id, { member_id }),
    {
      onSuccess: () => {
        message.success('杞淳鎴愬姛')
        setAssignModalVisible(false)
        assignForm.resetFields()
        queryClient.invalidateQueries(['workOrder', id])
        queryClient.invalidateQueries('workOrders')
        queryClient.invalidateQueries('notificationUnreadCount')
        queryClient.invalidateQueries('notificationsRecent')
      },
      onError: (error: any) => {
        message.error(extractErrorMessage(error, '杞淳澶辫触'))
      },
    }
  )

  // 瀹屾垚宸ュ崟 mutation
  const completeMutation = useMutation(
    (id: number) => workOrderService.completeWorkOrder(id),
    {
      onSuccess: () => {
        message.success('宸ュ崟宸插畬鎴?)
        queryClient.invalidateQueries(['workOrder', id])
        queryClient.invalidateQueries('workOrders')
        queryClient.invalidateQueries('notificationUnreadCount')
        queryClient.invalidateQueries('notificationsRecent')
      },
      onError: (error: any) => {
        message.error(extractErrorMessage(error, '瀹屾垚宸ュ崟澶辫触'))
      },
    }
  )

  // 淇敼缁勯暱 mutation
  const updateTeamLeaderMutation = useMutation(
    ({ id, data }: { id: number; data: { team_leader_id: number; reason?: string } }) =>
      workOrderService.updateWorkOrderTeamLeader(id, data),
    {
      onSuccess: () => {
        message.success('淇敼缁勯暱鎴愬姛')
        setUpdateTeamLeaderModalVisible(false)
        updateTeamLeaderForm.resetFields()
        queryClient.invalidateQueries(['workOrder', id])
        queryClient.invalidateQueries('workOrders')
        queryClient.invalidateQueries('notificationUnreadCount')
        queryClient.invalidateQueries('notificationsRecent')
      },
      onError: (error: any) => {
        message.error(extractErrorMessage(error, '淇敼缁勯暱澶辫触'))
      },
    }
  )

  // 鍙栨秷宸ュ崟 mutation
  const cancelMutation = useMutation(
    ({ id, data }: { id: number; data: { cancellation_reason?: string } }) =>
      workOrderService.cancelWorkOrder(id, data),
    {
      onSuccess: () => {
        message.success('宸ュ崟宸插彇娑?)
        setCancelModalVisible(false)
        cancelForm.resetFields()
        queryClient.invalidateQueries(['workOrder', id])
        queryClient.invalidateQueries('workOrders')
        queryClient.invalidateQueries('notificationUnreadCount')
        queryClient.invalidateQueries('notificationsRecent')
      },
      onError: (error: any) => {
        message.error(extractErrorMessage(error, '鍙栨秷宸ュ崟澶辫触'))
      },
    }
  )

  // 鎾ゅ洖宸ュ崟 mutation
  const revokeMutation = useMutation(
    (id: number) => workOrderService.revokeWorkOrder(id),
    {
      onSuccess: () => {
        message.success('宸ュ崟宸叉挙鍥?)
        queryClient.invalidateQueries(['workOrder', id])
        queryClient.invalidateQueries('workOrders')
        queryClient.invalidateQueries('notificationUnreadCount')
        queryClient.invalidateQueries('notificationsRecent')
      },
      onError: (error: any) => {
        message.error(extractErrorMessage(error, '鎾ゅ洖宸ュ崟澶辫触'))
      },
    }
  )

  // 鍒ゆ柇鏄惁鍙互鎺ュ崟锛氭垚鍛樿鑹诧紝宸ュ崟鐘舵€佷负pending_accept锛屼笖member_id绛変簬褰撳墠鐢ㄦ埛id
  const canAccept = 
    currentRole?.role === UserRole.MEMBER &&
    workOrder?.status === 'pending_accept' &&
    workOrder?.member_id === user?.id

  // 鍒ゆ柇鏄惁鍙互杞淳锛氱粍闀胯鑹诧紝宸ュ崟鐘舵€佷负pending_assign锛屼笖team_leader_id绛変簬褰撳墠鐢ㄦ埛id
  const canAssign = 
    currentRole?.role === UserRole.TEAM_LEADER &&
    workOrder?.status === 'pending_assign' &&
    workOrder?.team_leader_id === user?.id

  // 鍒ゆ柇鏄惁鍙互瀹屾垚宸ュ崟锛?  // 1. 鎴愬憳瑙掕壊锛氬伐鍗曠姸鎬佷负accepted鎴杋n_progress锛屼笖member_id绛変簬褰撳墠鐢ㄦ埛id
  // 2. 缁勯暱瑙掕壊锛氬伐鍗曠姸鎬佷负accepted鎴杋n_progress锛屼笖team_leader_id绛変簬褰撳墠鐢ㄦ埛id
  const canComplete = 
    workOrder &&
    (workOrder.status === 'accepted' || workOrder.status === 'in_progress') &&
    (
      (currentRole?.role === UserRole.MEMBER && workOrder.member_id === user?.id) ||
      (currentRole?.role === UserRole.TEAM_LEADER && workOrder.team_leader_id === user?.id)
    )

  // 鍒ゆ柇鏄惁鍙互淇敼缁勯暱锛氭€荤瑙掕壊锛屽伐鍗曠姸鎬佷负pending_assign銆乸ending_accept鎴朼ccepted
  // 绂佹鍦╥n_progress銆乧ompleted銆乧ancelled鐘舵€佹椂淇敼
  const canUpdateTeamLeader = 
    currentRole?.role === UserRole.MANAGER &&
    workOrder &&
    (workOrder.status === 'pending_assign' || 
     workOrder.status === 'pending_accept' || 
     workOrder.status === 'accepted')

  // 鍒ゆ柇鏄惁鍙互鎾ゅ洖宸ュ崟锛氱粍闀胯鑹诧紝宸ュ崟鐘舵€佷负pending_accept鎴朼ccepted锛屼笖team_leader_id绛変簬褰撳墠鐢ㄦ埛id锛屼笖鏈夋垚鍛?  const canRevoke = 
    currentRole?.role === UserRole.TEAM_LEADER &&
    workOrder &&
    (workOrder.status === 'pending_accept' || workOrder.status === 'accepted') &&
    workOrder.team_leader_id === user?.id &&
    workOrder.member_id

  // 鍒ゆ柇鏄惁鍙互鍙栨秷宸ュ崟锛?  // 1. 缁勯暱瑙掕壊锛氬伐鍗曠姸鎬佷负pending_assign鎴杙ending_accept锛屼笖team_leader_id绛変簬褰撳墠鐢ㄦ埛id
  // 2. 鎴愬憳瑙掕壊锛氬伐鍗曠姸鎬佷负pending_accept銆乤ccepted鎴杋n_progress锛屼笖member_id绛変簬褰撳墠鐢ㄦ埛id
  const canCancel = 
    workOrder &&
    workOrder.status !== 'cancelled' &&
    workOrder.status !== 'completed' &&
    (
      (currentRole?.role === UserRole.TEAM_LEADER && 
       (workOrder.status === 'pending_assign' || workOrder.status === 'pending_accept') &&
       workOrder.team_leader_id === user?.id) ||
      (currentRole?.role === UserRole.MEMBER && 
       (workOrder.status === 'pending_accept' || workOrder.status === 'accepted' || workOrder.status === 'in_progress') &&
       workOrder.member_id === user?.id)
    )

  const handleAccept = () => {
    if (workOrder) {
      acceptMutation.mutate(workOrder.id)
    }
  }

  const handleAssign = () => {
    setAssignModalVisible(true)
  }

  const handleComplete = () => {
    if (workOrder) {
      Modal.confirm({
        title: '纭瀹屾垚宸ュ崟',
        content: (
          <div>
            <p>纭畾瑕佸畬鎴愭宸ュ崟鍚楋紵瀹屾垚鍚庡皢閫氱煡鐩稿叧鐢ㄦ埛銆?/p>
            <p style={{ color: '#ff4d4f', marginTop: 8 }}>
              <strong>娉ㄦ剰锛?/strong>瀹屾垚鍚庣殑宸ュ崟灏嗘棤娉曞垱寤烘嫓璁挎棩蹇楋紝璇风‘淇濆凡瀹屾垚鎵€鏈夋嫓璁胯褰曞悗鍐嶅畬鎴愬伐鍗曘€?            </p>
          </div>
        ),
        okText: '纭',
        cancelText: '鍙栨秷',
        onOk: () => {
          completeMutation.mutate(workOrder.id)
        },
      })
    }
  }

  const handleUpdateTeamLeader = () => {
    setUpdateTeamLeaderModalVisible(true)
    // 璁剧疆榛樿鍊间负褰撳墠缁勯暱
    updateTeamLeaderForm.setFieldsValue({
      team_leader_id: workOrder?.team_leader_id,
      reason: '',
    })
  }

  const handleCancel = () => {
    setCancelModalVisible(true)
    cancelForm.resetFields()
  }

  const handleRevoke = () => {
    if (workOrder) {
      Modal.confirm({
        title: '纭鎾ゅ洖宸ュ崟',
        content: (
          <div>
            <p>纭畾瑕佹挙鍥炴宸ュ崟鐨勮浆娲惧悧锛熸挙鍥炲悗锛?/p>
            <ul style={{ marginTop: 8, paddingLeft: 20 }}>
              <li>宸ュ崟灏嗛噸缃负銆屽緟杞淳銆嶇姸鎬?/li>
              <li>鎴愬憳鍏崇郴灏嗚娓呯┖</li>
              <li>鍘熸垚鍛樺皢鏀跺埌鎾ゅ洖閫氱煡</li>
              {workOrder.status === 'accepted' && (
                <li style={{ color: '#ff4d4f' }}>
                  <strong>娉ㄦ剰锛?/strong>鎴愬憳宸叉帴鍗曪紝鎾ゅ洖鍚庡皢娓呯┖鎺ュ崟璁板綍
                </li>
              )}
            </ul>
          </div>
        ),
        okText: '纭鎾ゅ洖',
        cancelText: '鍙栨秷',
        okButtonProps: { danger: true },
        onOk: () => {
          revokeMutation.mutate(workOrder.id)
        },
      })
    }
  }

  if (isLoading) {
    return <Loading tip="鍔犺浇宸ュ崟璇︽儏..." />
  }

  if (error) {
    return <ErrorBoundary error={error as Error} onRetry={() => refetch()} title="鍔犺浇宸ュ崟澶辫触" />
  }

  if (!workOrder) {
    return (
      <Result
        status="404"
        title="404"
        subTitle="宸ュ崟涓嶅瓨鍦?
        extra={
          <Button type="primary" onClick={() => navigate(getReturnUrl())}>
            杩斿洖宸ュ崟鍒楄〃
          </Button>
        }
      />
    )
  }

  return (
    <div>
      <PageBreadcrumb
        items={[
          { title: '宸ュ崟绠＄悊', to: getReturnUrl() },
          { title: workOrder.work_order_no || '宸ュ崟璇︽儏' },
        ]}
      />

      <Card title="宸ュ崟璇︽儏">
        <Descriptions column={2} bordered>
          <Descriptions.Item label="宸ュ崟缂栧彿">{workOrder.work_order_no}</Descriptions.Item>
          <Descriptions.Item label="鐘舵€?>
            <Tag color={WorkOrderStatusColors[workOrder.status]}>
              {WorkOrderStatusLabels[workOrder.status] || workOrder.status}
            </Tag>
          </Descriptions.Item>
          <Descriptions.Item label="浠诲姟">
            {workOrder.task_name ? (
              <Space>
                <Button 
                  type="link" 
                  style={{ padding: 0 }}
                  onClick={() => navigate(`/tasks/${workOrder.task_id}`)}
                >
                  {workOrder.task_name}
                </Button>
                {workOrder.task_sales_unit && (
                  <span style={{ color: '#8c8c8c' }}>({workOrder.task_sales_unit})</span>
                )}
              </Space>
            ) : (
              <span>浠诲姟 #{workOrder.task_id}</span>
            )}
          </Descriptions.Item>
          <Descriptions.Item label="缁勯暱">
            {workOrder.team_leader_name ? (
              <span>{workOrder.team_leader_name}</span>
            ) : (
              <span>鐢ㄦ埛 #{workOrder.team_leader_id}</span>
            )}
          </Descriptions.Item>
          <Descriptions.Item label="缁勫埆">
            {workOrder.group_name || '-'}
          </Descriptions.Item>
          {workOrder.member_id ? (
            <Descriptions.Item label="鎴愬憳">
              {workOrder.member_name ? (
                <span>{workOrder.member_name}</span>
              ) : (
                <span>鐢ㄦ埛 #{workOrder.member_id}</span>
              )}
            </Descriptions.Item>
          ) : null}
          <Descriptions.Item label="鍒涘缓鏃堕棿" span={workOrder.member_id ? 1 : 2}>
            {dayjs(workOrder.created_at).format('YYYY-MM-DD HH:mm:ss')}
          </Descriptions.Item>
          
          {/* 璇︾粏闇€姹備俊鎭?*/}
          {workOrder.detail_requirement_id && (
            <>
              <Descriptions.Item label="瀹㈡埛鍗曚綅" span={2}>
                {workOrder.customer_unit || '-'}
              </Descriptions.Item>
              <Descriptions.Item label="琛屼笟绫诲瀷">
                {workOrder.industry_type || '-'}
              </Descriptions.Item>
              <Descriptions.Item label="瀹㈡埛鏉ユ簮">
                {workOrder.customer_source || '-'}
              </Descriptions.Item>
              <Descriptions.Item label="棰勬湡鎷滆鏃堕棿">
                {workOrder.expected_visit_time 
                  ? dayjs(workOrder.expected_visit_time).format('YYYY-MM-DD HH:mm')
                  : '-'}
              </Descriptions.Item>
              <Descriptions.Item label="瀹㈡埛鎷滆鍦板潃" span={2}>
                {workOrder.customer_visit_address || '-'}
              </Descriptions.Item>
              <Descriptions.Item label="瀹㈡埛缁忕悊濮撳悕">
                {workOrder.customer_manager_name || '-'}
              </Descriptions.Item>
              <Descriptions.Item label="瀹㈡埛缁忕悊鑱旂郴鏂瑰紡">
                {workOrder.customer_manager_contact || '-'}
              </Descriptions.Item>
              <Descriptions.Item label="鎻愪氦浜? span={2}>
                {workOrder.sales_contact_name || '-'}
                {workOrder.sales_contact_unit && (
                  <span style={{ color: '#8c8c8c', marginLeft: 8 }}>
                    ({workOrder.sales_contact_unit})
                  </span>
                )}
              </Descriptions.Item>
              <Descriptions.Item label="璇︾粏闇€姹傚唴瀹? span={2}>
                <div style={{ 
                  whiteSpace: 'pre-wrap', 
                  wordBreak: 'break-word',
                  maxHeight: '200px',
                  overflowY: 'auto',
                  padding: '8px',
                  backgroundColor: '#f5f5f5',
                  borderRadius: '4px'
                }}>
                  {workOrder.requirement_content || '-'}
                </div>
              </Descriptions.Item>
            </>
          )}
          {workOrder.accepted_at && (
            <Descriptions.Item label="鎺ュ崟鏃堕棿" span={2}>
              {dayjs(workOrder.accepted_at).format('YYYY-MM-DD HH:mm:ss')}
            </Descriptions.Item>
          )}
          {workOrder.completed_at && (
            <Descriptions.Item label="瀹屾垚鏃堕棿" span={2}>
              {dayjs(workOrder.completed_at).format('YYYY-MM-DD HH:mm:ss')}
            </Descriptions.Item>
          )}
          {workOrder.cancelled_at && (
            <Descriptions.Item label="鍙栨秷鏃堕棿" span={2}>
              {dayjs(workOrder.cancelled_at).format('YYYY-MM-DD HH:mm:ss')}
            </Descriptions.Item>
          )}
          {workOrder.cancellation_reason && (
            <Descriptions.Item label="鍙栨秷鍘熷洜" span={2}>
              <div style={{
                padding: '8px',
                backgroundColor: '#fff7e6',
                borderRadius: '4px',
                border: '1px solid #ffe58f'
              }}>
                {workOrder.cancellation_reason}
              </div>
            </Descriptions.Item>
          )}
        </Descriptions>

        {/* 鎿嶄綔鎸夐挳 */}
        {(canAccept || canAssign || canComplete || canCancel || canUpdateTeamLeader || canRevoke) && (
          <div style={{ marginTop: 24 }}>
            <Space>
              {canAccept && (
                <Button type="primary" onClick={handleAccept} loading={acceptMutation.isLoading}>
                  鎺ュ崟
                </Button>
              )}
              {canAssign && (
                <Button type="primary" onClick={handleAssign} loading={assignMutation.isLoading}>
                  {workOrder?.member_id ? '閲嶆柊杞淳' : '杞淳缁欐垚鍛?}
                </Button>
              )}
              {canRevoke && (
                <Button 
                  type="default" 
                  danger
                  onClick={handleRevoke} 
                  loading={revokeMutation.isLoading}
                >
                  鎾ゅ洖
                </Button>
              )}
              {canUpdateTeamLeader && (
                <Button type="default" onClick={handleUpdateTeamLeader}>
                  淇敼缁勯暱
                </Button>
              )}
              {canCancel && (
                <Button 
                  type="default" 
                  danger
                  onClick={handleCancel} 
                  loading={cancelMutation.isLoading}
                >
                  鍙栨秷宸ュ崟
                </Button>
              )}
              {canComplete && (
                <Button 
                  type="primary" 
                  danger
                  onClick={handleComplete} 
                  loading={completeMutation.isLoading}
                >
                  瀹屾垚宸ュ崟
                </Button>
              )}
            </Space>
          </div>
        )}
      </Card>

      {/* 杞淳妯℃€佹 */}
      <Modal
        title="杞淳宸ュ崟缁欐垚鍛?
        open={assignModalVisible}
        onCancel={() => {
          setAssignModalVisible(false)
          assignForm.resetFields()
        }}
        onOk={() => assignForm.submit()}
        confirmLoading={assignMutation.isLoading}
      >
        <Form
          form={assignForm}
          onFinish={(values) => {
            if (workOrder) {
              assignMutation.mutate({ id: workOrder.id, member_id: values.member_id })
            }
          }}
          layout="vertical"
        >
          <Form.Item
            name="member_id"
            label="閫夋嫨鎴愬憳"
            rules={[{ required: true, message: '璇烽€夋嫨鎴愬憳' }]}
            initialValue={workOrder?.member_id}
          >
            <UserSelector role={UserRole.MEMBER} myGroup={true} placeholder="璇烽€夋嫨鎴愬憳" />
          </Form.Item>
        </Form>
      </Modal>

      {/* 淇敼缁勯暱妯℃€佹 */}
      <Modal
        title="淇敼宸ュ崟缁勯暱"
        open={updateTeamLeaderModalVisible}
        onCancel={() => {
          setUpdateTeamLeaderModalVisible(false)
          updateTeamLeaderForm.resetFields()
        }}
        onOk={() => updateTeamLeaderForm.submit()}
        confirmLoading={updateTeamLeaderMutation.isLoading}
      >
        <Form
          form={updateTeamLeaderForm}
          onFinish={(values) => {
            if (workOrder) {
              updateTeamLeaderMutation.mutate({
                id: workOrder.id,
                data: {
                  team_leader_id: values.team_leader_id,
                  reason: values.reason || undefined,
                },
              })
            }
          }}
          layout="vertical"
        >
          <Form.Item label="褰撳墠缁勯暱">
            <span>{workOrder?.team_leader_name || `鐢ㄦ埛 #${workOrder?.team_leader_id}`}</span>
          </Form.Item>
          {workOrder?.member_name && (
            <Form.Item label="褰撳墠鎴愬憳">
              <span>{workOrder.member_name}</span>
            </Form.Item>
          )}
          <Form.Item
            name="team_leader_id"
            label="閫夋嫨鏂扮粍闀?
            rules={[{ required: true, message: '璇烽€夋嫨鏂扮粍闀? }]}
          >
            <UserSelector role={UserRole.TEAM_LEADER} placeholder="璇烽€夋嫨鏂扮粍闀? />
          </Form.Item>
          <Form.Item
            name="reason"
            label="淇敼鍘熷洜锛堝彲閫夛級"
          >
            <Input.TextArea
              rows={3}
              placeholder="璇疯緭鍏ヤ慨鏀瑰師鍥狅紝渚夸簬杩芥函"
              maxLength={500}
              showCount
            />
          </Form.Item>
          {(workOrder?.status === 'pending_accept' || workOrder?.status === 'accepted') && (
            <div style={{ 
              color: '#ff4d4f', 
              marginTop: 8,
              padding: '8px 12px',
              backgroundColor: '#fff2e8',
              borderRadius: '4px',
              border: '1px solid #ffbb96'
            }}>
              <strong>鈿狅笍 閲嶈鎻愮ず锛?/strong>
              <p style={{ margin: '4px 0 0 0' }}>
                褰撳墠宸ュ崟宸瞷workOrder?.status === 'pending_accept' ? '杞淳缁欐垚鍛? : '琚垚鍛樻帴鍗?}锛屼慨鏀圭粍闀垮悗灏嗭細
              </p>
              <ul style={{ margin: '4px 0 0 0', paddingLeft: '20px' }}>
                <li>娓呯┖鎴愬憳鍏崇郴</li>
                <li>閲嶇疆宸ュ崟鐘舵€佷负銆屽緟杞淳銆?/li>
                <li>鏂扮粍闀块渶瑕侀噸鏂拌浆娲剧粰鎴愬憳</li>
              </ul>
            </div>
          )}
        </Form>
      </Modal>

      {/* 鍙栨秷宸ュ崟妯℃€佹 */}
      <Modal
        title="鍙栨秷宸ュ崟"
        open={cancelModalVisible}
        onCancel={() => {
          setCancelModalVisible(false)
          cancelForm.resetFields()
        }}
        onOk={() => cancelForm.submit()}
        confirmLoading={cancelMutation.isLoading}
        okText="纭鍙栨秷"
        cancelText="鍙栨秷"
        okButtonProps={{ danger: true }}
      >
        <Form
          form={cancelForm}
          onFinish={(values) => {
            if (workOrder) {
              cancelMutation.mutate({
                id: workOrder.id,
                data: {
                  cancellation_reason: values.cancellation_reason || undefined,
                },
              })
            }
          }}
          layout="vertical"
        >
          <Form.Item
            name="cancellation_reason"
            label="鍙栨秷鍘熷洜锛堝彲閫夛級"
            help="濉啓鍙栨秷鍘熷洜鏈夊姪浜庤拷婧拰鍒嗘瀽锛屽缓璁～鍐?
          >
            <Input.TextArea
              rows={4}
              placeholder="璇疯緭鍏ュ彇娑堝師鍥狅紝渚嬪锛氬鎴烽渶姹傚彉鏇淬€佹椂闂村啿绐佺瓑"
              maxLength={500}
              showCount
            />
          </Form.Item>
          <div style={{ color: '#ff4d4f', marginTop: 8 }}>
            <strong>娉ㄦ剰锛?/strong>鍙栨秷鍚庣殑宸ュ崟灏嗘棤娉曠户缁搷浣滐紝璇风‘璁ゅ悗鍐嶆彁浜ゃ€?          </div>
        </Form>
      </Modal>
    </div>
  )
}

export default WorkOrderDetail

